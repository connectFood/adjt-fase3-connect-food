    {
      "name": "00 - Setup Run",
      "item": [
        {
          "name": "00.01 - Setup Run",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "const keys = [",
                  "  'initialized',",
                  "  'runInitialized',",
                  "  'runMarker',",
                  "  'runId',",
                  "  'customerEmail',",
                  "  'adminEmail',",
                  "  'ownerEmail',",
                  "  'invalidRoleEmail',",
                  "  'customerPassword',",
                  "  'adminPassword',",
                  "  'ownerPassword',",
                  "  'customerName',",
                  "  'adminName',",
                  "  'ownerName',",
                  "  'customerRestaurantId',",
                  "  'adminRestaurantId',",
                  "  'ownerRestaurantId',",
                  "  'customerBurgerItemId',",
                  "  'customerBurgerName',",
                  "  'customerDrinkItemId',",
                  "  'customerDrinkName',",
                  "  'adminItemId',",
                  "  'adminItemName',",
                  "  'ownerItemId',",
                  "  'ownerItemName',",
                  "  'customerUuid',",
                  "  'adminUuid',",
                  "  'ownerUuid',",
                  "  'customerAccessToken',",
                  "  'customerRefreshToken',",
                  "  'adminAccessToken',",
                  "  'adminRefreshToken',",
                  "  'ownerAccessToken',",
                  "  'ownerRefreshToken',",
                  "  'customerOrderUuid',",
                  "  'adminOrderUuid',",
                  "  'ownerOrderUuid'",
                  "];",
                  "",
                  "keys.forEach((key) => pm.collectionVariables.unset(key));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "pm.test('Setup executado com sucesso', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{authBaseUrl}}/actuator/health",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            },
            "description": "Request inicial do Runner para limpar as collection variables antes da coleção reinicializar a massa dinâmica."
          },
          "response": []
        }
      ]
    },
