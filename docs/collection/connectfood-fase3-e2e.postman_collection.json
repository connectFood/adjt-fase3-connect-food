        "type": "text/javascript",
        "requests": {},
        "exec": [
          "if (!pm.collectionVariables.get('initialized')) {",
          "    const runId = pm.variables.replaceIn('{{$timestamp}}-{{$randomInt}}');",
          "",
          "    pm.collectionVariables.set('runId', runId);",
          "    pm.collectionVariables.set('customerEmail', pm.variables.replaceIn('customer.{{$guid}}@mailinator.com'));",
          "    pm.collectionVariables.set('adminEmail', pm.variables.replaceIn('admin.{{$guid}}@mailinator.com'));",
          "    pm.collectionVariables.set('ownerEmail', pm.variables.replaceIn('owner.{{$guid}}@mailinator.com'));",
          "    pm.collectionVariables.set('invalidRoleEmail', pm.variables.replaceIn('invalid-role.{{$guid}}@mailinator.com'));",
          "",
          "    pm.collectionVariables.set('customerPassword', pm.variables.replaceIn('Customer@{{$randomInt}}A'));",
          "    pm.collectionVariables.set('adminPassword', pm.variables.replaceIn('Admin@{{$randomInt}}A'));",
          "    pm.collectionVariables.set('ownerPassword', pm.variables.replaceIn('Owner@{{$randomInt}}A'));",
          "",
          "    pm.collectionVariables.set('customerName', pm.variables.replaceIn('Cliente {{$randomFirstName}} {{$randomLastName}}'));",
          "    pm.collectionVariables.set('adminName', pm.variables.replaceIn('Admin {{$randomFirstName}} {{$randomLastName}}'));",
          "    pm.collectionVariables.set('ownerName', pm.variables.replaceIn('Owner {{$randomFirstName}} {{$randomLastName}}'));",
          "",
          "    pm.collectionVariables.set('customerRestaurantId', pm.variables.replaceIn('rest-customer-{{$guid}}'));",
          "    pm.collectionVariables.set('adminRestaurantId', pm.variables.replaceIn('rest-admin-{{$guid}}'));",
          "    pm.collectionVariables.set('ownerRestaurantId', pm.variables.replaceIn('rest-owner-{{$guid}}'));",
          "",
          "    pm.collectionVariables.set('customerBurgerItemId', pm.variables.replaceIn('burger-{{$guid}}'));",
          "    pm.collectionVariables.set('customerBurgerName', pm.variables.replaceIn('burger-{{$randomInt}}'));",
          "    pm.collectionVariables.set('customerDrinkItemId', pm.variables.replaceIn('drink-{{$guid}}'));",
          "    pm.collectionVariables.set('customerDrinkName', pm.variables.replaceIn('drink-{{$randomInt}}'));",
          "",
          "    pm.collectionVariables.set('adminItemId', pm.variables.replaceIn('admin-item-{{$guid}}'));",
          "    pm.collectionVariables.set('adminItemName', pm.variables.replaceIn('burger-{{$guid}}'));",
          "    pm.collectionVariables.set('ownerItemId', pm.variables.replaceIn('owner-item-{{$guid}}'));",
          "    pm.collectionVariables.set('ownerItemName', pm.variables.replaceIn('burger-{{$guid}}'));",
          "",
          "    pm.collectionVariables.set('initialized', 'true');",
          "}",
          "",
          "function parseJsonSafe() {",
          "  try {",
          "    return pm.response.json();",
          "  } catch (e) {",
          "    return null;",
          "  }",
          "}",
          "",
          "function firstValue() {",
          "  for (let i = 0; i < arguments.length; i += 1) {",
          "    const value = arguments[i];",
          "    if (value !== undefined && value !== null && value !== '') {",
          "      return value;",
          "    }",
          "  }",
          "  return null;",
          "}",
          "",
          "pm.globals.set('cf_parseJsonSafe', parseJsonSafe.toString());",
          "pm.globals.set('cf_firstValue', firstValue.toString());"
        ]
      }
    },
