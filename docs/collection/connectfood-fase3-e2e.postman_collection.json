{
  "info": {
    "_postman_id": "67d8f8cf-4c74-4a1a-8fd4-0f4e8d9fd301",
    "name": "Connect Food - Fase 3 - E2E",
    "description": "Collection E2E para os fluxos obrigatorios do Tech Challenge Fase 3. Cobre cadastro de usuarios, autenticacao, renovacao de token, validacao de acesso e fluxo de pedidos. A collection reflete exatamente o comportamento implementado no codigo atual: /auth/register, /auth/login e /auth/refresh sao publicos; /auth/me e todos os endpoints de /orders exigem JWT valido; no order-service nao ha restricao adicional por role no estado atual do projeto.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  const runId = Date.now().toString();",
          "  pm.collectionVariables.set('runId', runId);",
          "  pm.collectionVariables.set('password', 'ConnectFood@123');",
          "  pm.collectionVariables.set('customerEmail', `customer.${runId}@mailinator.com`);",
          "  pm.collectionVariables.set('adminEmail', `admin.${runId}@mailinator.com`);",
          "  pm.collectionVariables.set('ownerEmail', `owner.${runId}@mailinator.com`);",
          "  pm.collectionVariables.set('invalidToken', 'invalid.jwt.token');",
          "}",
          "if (!pm.collectionVariables.get('authBaseUrl')) {",
          "  pm.collectionVariables.set('authBaseUrl', 'http://localhost:8081');",
          "}",
          "if (!pm.collectionVariables.get('orderBaseUrl')) {",
          "  pm.collectionVariables.set('orderBaseUrl', 'http://localhost:8082');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code is present', function () {",
          "  pm.expect(pm.response.code).to.be.a('number');",
          "});",
          "pm.test('Response time below 4000ms', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(4000);",
          "});"
        ]
      }
    }
  ],
