    {
      "name": "04 - Fluxo de Pedidos",
      "item": [
        {
          "name": "04.01 - CUSTOMER cria pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.expect(pm.response.code).to.eql(201));",
                  "const json = pm.response.json();",
                  "pm.test('orderUuid presente', () => pm.expect(json.orderUuid).to.match(/^[0-9a-fA-F-]{36}$/));",
                  "pm.test('status CREATED', () => pm.expect(json.status).to.eql('CREATED'));",
                  "pm.collectionVariables.set('customerOrderUuid', json.orderUuid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"rest-customer\",\n  \"items\": [\n    {\n      \"itemId\": \"burger-1\",\n      \"itemName\": \"Classic Burger\",\n      \"quantity\": 2,\n      \"unitPrice\": 19.90\n    },\n    {\n      \"itemId\": \"soda-1\",\n      \"itemName\": \"Soda\",\n      \"quantity\": 1,\n      \"unitPrice\": 7.50\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{orderBaseUrl}}/orders",
              "host": ["{{orderBaseUrl}}"],
              "path": ["orders"]
            }
          },
          "response": []
        },
        {
          "name": "04.02 - CUSTOMER consulta pedido por UUID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.expect(pm.response.code).to.eql(200));",
                  "const json = pm.response.json();",
                  "pm.test('uuid confere', () => pm.expect(json.orderUuid).to.eql(pm.collectionVariables.get('customerOrderUuid')));",
                  "pm.test('customerUuid confere', () => pm.expect(json.customerUuid).to.eql(pm.collectionVariables.get('customerUuid')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerAccessToken}}" }
            ],
            "url": {
              "raw": "{{orderBaseUrl}}/orders/{{customerOrderUuid}}",
              "host": ["{{orderBaseUrl}}"],
              "path": ["orders", "{{customerOrderUuid}}"]
            }
          },
          "response": []
        },
